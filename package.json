{
  "name": "pawbloom",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-first PawBloom mobile app repository.",
  "scripts": {
    "start": "npm run codex:check",
    "codex:run": "./script/build_and_run.sh",
    "mobile:start": "npm --prefix apps/mobile run start",
    "mobile:android": "npm --prefix apps/mobile run android",
    "mobile:ios": "npm --prefix apps/mobile run ios",
    "mobile:web": "npm --prefix apps/mobile run web",
    "mobile:export-web": "npm --prefix apps/mobile run export:web",
    "mobile:preview-web": "node scripts/serve-expo-web.mjs --host 127.0.0.1 --port 8082",
    "typecheck": "npm --prefix apps/mobile run typecheck",
    "verify:architecture": "node scripts/verify-architecture.mjs",
    "verify:i18n": "node scripts/verify-i18n.mjs",
    "verify:presentation": "node scripts/verify-presentation-state.mjs",
    "verify:ai-safety": "node scripts/verify-ai-safety.mjs",
    "verify:secrets": "node scripts/verify-secrets.mjs",
    "verify:supabase": "node scripts/verify-supabase.mjs",
    "verify:offline": "node scripts/verify-offline-sync.mjs",
    "codex:check": "node scripts/codex-environment-check.mjs",
    "verify": "npm run typecheck && npm run verify:architecture && npm run verify:i18n && npm run verify:presentation && npm run verify:ai-safety && npm run verify:secrets && npm run verify:supabase && npm run verify:offline"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
